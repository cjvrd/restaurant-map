datasource db {
    provider = "postgresql"
    url      = "postgresql://postgres:postgres@db:5432/postgres"
}

generator kysely {
    provider = "prisma-kysely"
    output   = "../"
    fileName = "types.ts"
}

model Restaurant {
    id           Int      @id @default(autoincrement())
    created_time DateTime @default(now())
    updated_time DateTime @updatedAt
    status       status   @default(ENABLED)
    name         String
    address      String?
    coordinates  Json? // { lng: 0.0, lat: 0.0 }
    phone        String?
    website      String?
    description  String?
    rating       Int? // 1-5 stars
    review       String?
    visit        visit_status?
    google_place_id  String?  @unique
    price_level      String?
    types            Json?
    google_rating    Float?
    google_rating_count Int?
}

enum status {
    ENABLED
    DISABLED
    DELETED
}

enum visit_status {
    VISIT
    VISITED
}
